# Immich Environment Variables
# Documentation: https://docs.immich.app/install/environment-variables

# The location where your uploaded files are stored
UPLOAD_LOCATION=./library

# The location where your database files are stored
# Network shares are NOT supported for the database
DB_DATA_LOCATION=./postgres

# Timezone - Change to your timezone
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones#List
TZ=America/Los_Angeles

# The Immich version to use. You can pin this to a specific version like "v2.1.0"
IMMICH_VERSION=v2

# Connection secret for postgres. CHANGE THIS to a random strong password.
# Please use only the characters `A-Za-z0-9`, without special characters or spaces.
DB_PASSWORD=CHANGE_ME_BEFORE_FIRST_RUN

###################################################################################
# The values below this line do not need to be changed
###################################################################################
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
